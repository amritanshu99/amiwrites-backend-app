PORT=5000
NODE_ENV=development

# Required
MONGO_URI=mongodb+srv://USER:PASSWORD@HOST/DATABASE?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret

# CORS
# Loopback localhost origins on any port are allowed automatically when NODE_ENV is not production.
CLIENT_URL=https://www.amiverse.in
ALLOWED_ORIGINS=https://www.amiverse.in,https://amiverse.in
CORS_CREDENTIALS=false
CORS_MAX_AGE_SECONDS=600
REQUEST_BODY_LIMIT=1mb

# Email via Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
MAIL_FROM=AmiVerse <noreply@amiverse.in>
CONTACT_TO_EMAIL=amritanshu0909@gmail.com
PUBLIC_FRONTEND_URL=https://www.amiverse.in

# External APIs
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxx
NEWS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxx

# Web push
VAPID_SUBJECT=mailto:amritanshu0909@gmail.com
VAPID_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxx

# Optional tuning
MONGO_SERVER_SELECTION_TIMEOUT_MS=30000
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=30
PUBLIC_WRITE_RATE_LIMIT_WINDOW_MS=900000
PUBLIC_WRITE_RATE_LIMIT_MAX=120
AI_RATE_LIMIT_WINDOW_MS=900000
AI_RATE_LIMIT_MAX=60
EVENT_RATE_LIMIT_WINDOW_MS=900000
EVENT_RATE_LIMIT_MAX=300
